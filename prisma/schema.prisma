generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Article {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  excerpt   String
  content   String   @db.Text
  image     String
  category  String
  authorName  String   @default("Admin")
  publishedAt DateTime @default(now())
  createdAt DateTime @default(now())
}

model Documentation {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  coverImage  String
  createdAt   DateTime @default(now())

  images DocumentationImage[]
}

model DocumentationImage {
  id               Int  @id @default(autoincrement())
  imageUrl         String
  documentationId  Int
  documentation    Documentation @relation(fields: [documentationId], references: [id], onDelete: Cascade)
}

